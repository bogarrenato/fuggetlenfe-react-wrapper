{
  "name": "@fuggetlenfe/react-wrapper",
  "version": "0.2.0",
  "description": "React wrapper for @fuggetlenfe/components.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bogarrenato/fuggetlenfe-react-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/bogarrenato/fuggetlenfe-react-wrapper/issues"
  },
  "homepage": "https://bogarrenato.github.io/fuggetlenfe-react-wrapper/latest/",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:demo": "npm run build --prefix demo",
    "build:docs-site": "node scripts/build-docs-site.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@fuggetlenfe/components": "^0.2.0",
    "@stencil/react-output-target": "^0.8.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3"
  }
}
